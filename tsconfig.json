{
  "compilerOptions": {
    "esModuleInterop": true,
    "lib": ["es2016"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmit": true,
    "noEmitOnError": true,
    "outDir": "./dist",
    "paths": {
      "/*": ["./src/*"]
    },
    "rootDir": ".",
    "skipLibCheck": true,
    "strict": true,
    "target": "es2016",
    "types": ["node"]
  },
  "exclude": [],
  "include": ["src", "test"]
}
